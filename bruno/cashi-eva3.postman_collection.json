{
  "info": {
    "name": "Cashi API - EVA3",
    "description": "Coleccion para probar todos los endpoints esperados de EVA3: autenticacion, categorias, transacciones, balance y comprobantes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "paste-token-here",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "01 Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"camila@example.com\",\n  \"password\": \"123456\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": "{{baseUrl}}/auth/register"
      }
    },
    {
      "name": "02 Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"camila@example.com\",\n  \"password\": \"123456\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": "{{baseUrl}}/auth/login"
      }
    },
    {
      "name": "03 List Categories",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{baseUrl}}/categories"
      }
    },
    {
      "name": "04 Create Category",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Sueldo\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": "{{baseUrl}}/categories"
      }
    },
    {
      "name": "05 Update Category",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Sueldo actualizado\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": "{{baseUrl}}/categories/1"
      }
    },
    {
      "name": "06 Delete Category",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{baseUrl}}/categories/1"
      }
    },
    {
      "name": "07 List Transactions",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{baseUrl}}/transactions"
      }
    },
    {
      "name": "08 Get Transaction By Id",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{baseUrl}}/transactions/1"
      }
    },
    {
      "name": "09 Create Transaction",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": 850000,\n  \"type\": \"income\",\n  \"description\": \"Pago de sueldo\",\n  \"date\": \"2026-05-10\",\n  \"categoryId\": 1,\n  \"receiptUrl\": \"https://pub-7e000acc95024afc8cf4319802525457.r2.dev/receipts/demo.jpg\",\n  \"latitude\": -33.4489,\n  \"longitude\": -70.6693\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": "{{baseUrl}}/transactions"
      }
    },
    {
      "name": "10 Update Transaction",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": 900000,\n  \"type\": \"income\",\n  \"description\": \"Sueldo actualizado\",\n  \"date\": \"2026-05-10\",\n  \"categoryId\": 1,\n  \"receiptUrl\": \"https://pub-7e000acc95024afc8cf4319802525457.r2.dev/receipts/demo-actualizado.jpg\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": "{{baseUrl}}/transactions/1"
      }
    },
    {
      "name": "11 Delete Transaction",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{baseUrl}}/transactions/1"
      }
    },
    {
      "name": "12 Balance",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{baseUrl}}/transactions/balance"
      }
    },
    {
      "name": "13 Upload Receipt",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "receipt",
              "type": "file",
              "src": []
            }
          ]
        },
        "url": "{{baseUrl}}/transactions/upload"
      }
    }
  ]
}
